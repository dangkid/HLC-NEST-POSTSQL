FROM ubuntu

# Remplazar sources.list con mirror alternativo
RUN cat > /etc/apt/sources.list << 'EOF'
deb http://mirrors.edge.kernel.org/ubuntu noble main restricted universe multiverse
deb http://mirrors.edge.kernel.org/ubuntu noble-security main restricted universe multiverse
deb http://mirrors.edge.kernel.org/ubuntu noble-updates main restricted universe multiverse
deb http://mirrors.edge.kernel.org/ubuntu noble-backports main restricted universe multiverse
EOF
RUN apt update && apt install -y --no-install-recommends \
    curl \
    nano \
    net-tools iputils-ping \
    sudo \
    openssh-server 

RUN mkdir -p /root/admin/base
WORKDIR /root/admin/base
COPY ./dockerfiles/ubbase/admin/ .

COPY ./common/id_rsa.pub ./common/id_rsa.pub
RUN chmod +x ./damgstart.sh

ENTRYPOINT [ "./damgstart.sh" ]
