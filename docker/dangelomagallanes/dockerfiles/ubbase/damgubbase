FROM ubuntu

# Cambiar a mirror alternativo de Ubuntu (more-stable.com)
RUN sed -i 's|archive.ubuntu.com|mirrors.edge.kernel.org/ubuntu|g' /etc/apt/sources.list && \
    sed -i 's|security.ubuntu.com|mirrors.edge.kernel.org/ubuntu-security|g' /etc/apt/sources.list && \
    apt update && apt install -y --no-install-recommends \
    curl \
    nano \
    net-tools iputils-ping \
    sudo \
    openssh-server 

RUN mkdir -p /root/admin/base
WORKDIR /root/admin/base
COPY ./dockerfiles/ubbase/admin/ .

COPY ./common/id_rsa.pub ./common/id_rsa.pub
RUN chmod +x ./damgstart.sh

ENTRYPOINT [ "./damgstart.sh" ]
