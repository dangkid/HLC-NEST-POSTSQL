FROM node:22-alpine

RUN apk add --no-cache netcat-openbsd bash

WORKDIR /app

# Copy NestJS project only
COPY proyecto/nest_api/proyecto/package*.json ./
COPY proyecto/nest_api/proyecto/.npmrc ./
COPY proyecto/nest_api/proyecto/tsconfig*.json ./
COPY proyecto/nest_api/proyecto/src ./src
COPY proyecto/nest_api/proyecto/test ./test
COPY proyecto/nest_api/proyecto/*.json ./
COPY proyecto/nest_api/proyecto/entrypoint.sh ./

RUN chmod +x entrypoint.sh

EXPOSE 3001

ENTRYPOINT ["./entrypoint.sh"]
